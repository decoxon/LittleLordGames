---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import TagChip from '../components/TagChip.astro';
import { postSummary, formatDate, type Post } from '../lib/posts';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { title, date, tags, heroImage, heroAlt } = post.data;
const description = postSummary(post);
const ogImage = heroImage?.src;
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  article
  publishedDate={date}
  tags={tags}
>
  <article class="post" data-pagefind-body>
    <header class="post__header">
      <h1>{title}</h1>
      <p class="post__meta">
        <time datetime={date.toISOString()} data-pagefind-meta="date">
          {formatDate(date)}
        </time>
      </p>
      <ul class="post__tags">
        {tags.map((tag) => (
          <li>
            <TagChip tag={tag} />
          </li>
        ))}
      </ul>
    </header>

    {
      heroImage && (
        <figure class="post__hero">
          <Image
            src={heroImage}
            alt={heroAlt ?? ''}
            widths={[480, 960, 1440]}
            sizes="(max-width: 48rem) 100vw, 46rem"
          />
        </figure>
      )
    }

    <div class="post__body">
      <slot />
    </div>

    <footer class="post__footer">
      <a href="/">← Back to all posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    padding-block: var(--space-8);
  }
  .post__header {
    margin-bottom: var(--space-6);
  }
  .post__meta {
    font-family: var(--font-pixel-soft);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }
  .post__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
  }
  .post__hero {
    margin: 0 0 var(--space-8);
  }
  .post__hero :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    border: var(--border-width) solid var(--color-border);
  }

  /* readable body column; images/figures handled in global for markdown */
  .post__body :global(img) {
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }
  .post__body :global(figure.post-figure) {
    margin-inline: 0;
    margin-block: var(--space-6);
    text-align: center;
  }
  .post__body :global(figcaption) {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
    margin-top: var(--space-2);
    font-style: italic;
  }

  /* lists */
  .post__body :global(ul),
  .post__body :global(ol) {
    padding-left: 1.4em;
  }
  .post__body :global(li + li) {
    margin-top: var(--space-2);
  }
  .post__body :global(li > ul),
  .post__body :global(li > ol) {
    margin-top: var(--space-2);
  }

  /* tables */
  .post__body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }
  .post__body :global(th),
  .post__body :global(td) {
    border: 1px solid var(--color-border);
    padding: var(--space-2) var(--space-3);
    text-align: left;
  }
  .post__body :global(thead th) {
    background: var(--color-surface-alt);
    font-family: var(--font-pixel-soft);
    font-weight: 400;
  }

  /* prose links stay underlined for legibility */
  .post__body :global(a) {
    text-decoration: underline;
  }

  .post__footer {
    margin-top: var(--space-12);
    padding-top: var(--space-4);
    border-top: 2px dashed var(--color-border);
    font-family: var(--font-pixel-soft);
    font-size: 0.8rem;
  }
</style>
