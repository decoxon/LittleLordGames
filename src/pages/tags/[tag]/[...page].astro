---
import type { GetStaticPaths, Page } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import TagSidebar from '../../../components/TagSidebar.astro';
import Pagination from '../../../components/Pagination.astro';
import {
  getAllTags,
  getPostsByTag,
  tagSlug,
  POSTS_PER_PAGE,
  type Post,
} from '../../../lib/posts';

export const getStaticPaths = (async ({ paginate }) => {
  const tags = await getAllTags();
  const paths = [];
  for (const { tag } of tags) {
    const posts = await getPostsByTag(tag);
    paths.push(
      ...paginate(posts, {
        params: { tag: tagSlug(tag) },
        props: { tag },
        pageSize: POSTS_PER_PAGE,
      })
    );
  }
  return paths;
}) satisfies GetStaticPaths;

const { page, tag } = Astro.props as { page: Page<Post>; tag: string };
const slug = tagSlug(tag);
const allTags = await getAllTags();
const pageUrl = (n: number) =>
  n === 1 ? `/tags/${slug}/` : `/tags/${slug}/${n}/`;
---

<BaseLayout wide title={`#${tag}`} description={`Posts tagged “${tag}”.`}>
  <div class="feed-layout">
    <div class="feed">
      <h1 class="feed__title">#{tag}</h1>
      {page.data.map((post) => <PostCard post={post} />)}
      <Pagination
        currentPage={page.currentPage}
        lastPage={page.lastPage}
        pageUrl={pageUrl}
      />
    </div>
    <TagSidebar tags={allTags} activeTag={tag} />
  </div>
</BaseLayout>
