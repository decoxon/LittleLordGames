---
import { Image } from 'astro:assets';
import TagChip from './TagChip.astro';
import { postSummary, formatDate, type Post } from '../lib/posts';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { title, date, tags, heroImage, heroAlt } = post.data;
const href = `/blog/${post.id}/`;
const summary = postSummary(post);
---

<article class="card">
  {
    heroImage && (
      <a class="card__media" href={href} tabindex="-1" aria-hidden="true">
        <Image
          src={heroImage}
          alt={heroAlt ?? ''}
          widths={[400, 800]}
          sizes="(max-width: 52rem) 100vw, 22rem"
          loading="lazy"
        />
      </a>
    )
  }
  <div class="card__body">
    <h2 class="card__title">
      <a href={href}>{title}</a>
    </h2>
    <p class="card__meta">
      <time datetime={date.toISOString()}>{formatDate(date)}</time>
    </p>
    <p class="card__excerpt">{summary}</p>
    {
      tags.length > 0 && (
        <ul class="card__tags">
          {tags.map((tag) => (
            <li>
              <TagChip tag={tag} />
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>

<style>
  .card {
    display: grid;
    grid-template-columns: 1fr;
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-6);
    box-shadow: 0 2px 0 var(--color-shadow);
  }
  .card:hover {
    border-color: var(--color-accent);
  }
  .card__media {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface-alt);
  }
  .card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card__body {
    padding: var(--space-4) var(--space-6) var(--space-6);
  }
  .card__title {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-2);
  }
  .card__title a {
    color: var(--color-heading);
    text-decoration: none;
  }
  .card__title a:hover {
    color: var(--color-link-hover);
  }
  .card__meta {
    font-family: var(--font-pixel-soft);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }
  .card__excerpt {
    margin: 0 0 var(--space-4);
    color: var(--color-text);
  }
  .card__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
  }
</style>
